          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"environment\": \"dev\",\n  \"method\": \"FEXGetLast_ID\",\n  \"wsid\": \"wsfex\",\n  \"params\": {\n    \"Auth\": {\n      \"Token\": \"{{ $('get_authorization').item.json.token }}\",\n      \"Sign\": \"{{ $('get_authorization').item.json.sign }}\",\n      \"Cuit\": 20400832278\n    },\n    \"PtoVta\": 2,\n    \"CbteTipo\": 19\n  }\n}",
        "options": {}
      }
    },
    {
