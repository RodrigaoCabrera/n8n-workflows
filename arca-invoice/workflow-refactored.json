      }
    },
    {
      "id": "node-0002",
      "name": "validate_input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1540, 300],
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\n// Validate required fields\nconst required = ['client_name', 'client_tax_id', 'client_address', 'client_country', 'description', 'amount_usd'];\nfor (const f of required) {\n  if (!d[f] || String(d[f]).trim() === '') throw new Error('Campo requerido faltante: ' + f);\n}\n\nconst amount = parseFloat(d.amount_usd);\nconst qty = parseInt(d.quantity) || 1;\nif (isNaN(amount) || amount <= 0) throw new Error('El monto debe ser mayor a 0');\nif (qty <= 0) throw new Error('La cantidad debe ser mayor a 0');\n\n// Country → AFIP codes\nconst COUNTRIES = {\n  'ESTADOS UNIDOS': { dst: 212, cuit: 50000000016 },\n  'URUGUAY':        { dst: 225, cuit: 50000000858 },\n  'BRASIL':         { dst: 109, cuit: 50000000076 },\n  'CHILE':          { dst: 113, cuit: 50000000152 },\n  'COLOMBIA':       { dst: 117, cuit: 50000000232 },\n  'MEXICO':         { dst: 167, cuit: 50000000484 },\n  'ESPANA':         { dst: 123, cuit: 50000000131 },\n  'CANADA':         { dst: 111, cuit: 50000000101 },\n  'ALEMANIA':       { dst: 102, cuit: 50000000104 },\n  'REINO UNIDO':    { dst: 200, cuit: 50000000826 }\n};\n\nconst key = String(d.client_country).toUpperCase().trim();\nconst country = COUNTRIES[key];\nif (!country) throw new Error('Pais no soportado: ' + key + '. Opciones: ' + Object.keys(COUNTRIES).join(', '));\n\n// Generate YYYYMMDD dates\nconst pad2 = n => String(n).padStart(2, '0');\nconst toAfipDate = dt => dt.getFullYear() + pad2(dt.getMonth() + 1) + pad2(dt.getDate());\nconst now = new Date();\n\nreturn [{ json: {\n  client_name:    String(d.client_name).trim(),\n  client_tax_id:  String(d.client_tax_id).trim(),\n  client_address: String(d.client_address).trim(),\n  client_country: key,\n  dst_cmp:        country.dst,\n  cuit_pais:      country.cuit,\n  description:    String(d.description).trim(),\n  amount:         amount,\n  quantity:       qty,\n  unit_price:     amount / qty,\n  payment_method: String(d.payment_method || 'Transferencia bancaria').trim(),\n  fecha_cbte:     toAfipDate(now),\n  fecha_pago:     toAfipDate(new Date(now.getTime() + 30 * 24 * 60 * 60 * 1000))\n}}];"
      }
    },
    {
