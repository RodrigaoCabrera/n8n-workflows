              "requiredField": true
            },
            {
              "fieldLabel": "client_tax_id",
              "placeholder": "ID fiscal / tax ID del cliente",
              "requiredField": true
            },
            {
              "fieldLabel": "client_address",
              "placeholder": "Domicilio completo del cliente",
              "requiredField": true
            },
            {
              "fieldLabel": "client_country",
              "fieldType": "dropdown",
              "requiredField": true,
              "fieldOptions": {
                "values": [
                  { "option": "ESTADOS UNIDOS" },
                  { "option": "URUGUAY" },
                  { "option": "BRASIL" },
                  { "option": "CHILE" },
                  { "option": "COLOMBIA" },
                  { "option": "MEXICO" },
                  { "option": "ESPANA" },
                  { "option": "CANADA" },
                  { "option": "ALEMANIA" },
                  { "option": "REINO UNIDO" }
                ]
              }
            },
            {
              "fieldLabel": "description",
              "placeholder": "Descripcion del servicio o producto",
              "requiredField": true
            },
            {
              "fieldLabel": "amount_usd",
              "fieldType": "number",
              "placeholder": "Monto total en USD",
              "requiredField": true
            },
            {
              "fieldLabel": "quantity",
              "fieldType": "number",
              "placeholder": "Cantidad (default: 1)",
              "requiredField": false
            },
            {
              "fieldLabel": "payment_method",
              "fieldType": "dropdown",
              "requiredField": true,
              "fieldOptions": {
                "values": [
                  { "option": "Transferencia bancaria" },
                  { "option": "Wire Transfer" },
                  { "option": "Payoneer" },
                  { "option": "Wise" },
                  { "option": "Otro" }
                ]
              }
            }
          ]
        },
