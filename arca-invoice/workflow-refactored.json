    {
      "id": "node-0007",
      "name": "create_voucher",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-440, 300],
      "continueOnFail": true,
      "parameters": {
        "method": "POST",
        "url": "https://app.afipsdk.com/api/v1/afip/requests",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.AFIP_SDK_TOKEN }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"environment\": \"dev\",\n  \"method\": \"FEXAuthorize\",\n  \"wsid\": \"wsfex\",\n  \"params\": {\n    \"Auth\": {\n      \"Token\": \"{{ $('get_authorization').item.json.token }}\",\n      \"Sign\": \"{{ $('get_authorization').item.json.sign }}\",\n      \"Cuit\": 20400832278\n    },\n    \"Cmp\": {\n      \"Id\": {{ $('get_last_id').item.json.FEXGetLast_IDResult.FEXResultGet.Id + 1 }},\n      \"Fecha_cbte\": \"{{ $('validate_input').item.json.fecha_cbte }}\",\n      \"Cbte_Tipo\": 19,\n      \"Punto_vta\": 2,\n      \"Cbte_nro\": {{ $('get_last_cmp').item.json.FEXGetLast_CMPResult.FEXResult_LastCMP.Cbte_nro + 1 }},\n      \"Tipo_expo\": 2,\n      \"Permiso_existente\": \"\",\n      \"Dst_cmp\": {{ $('validate_input').item.json.dst_cmp }},\n      \"Cliente\": \"{{ $('validate_input').item.json.client_name }}\",\n      \"Cuit_pais_cliente\": \"{{ $('validate_input').item.json.cuit_pais }}\",\n      \"Domicilio_cliente\": \"{{ $('validate_input').item.json.client_address }}\",\n      \"Id_impositivo\": \"{{ $('validate_input').item.json.client_tax_id }}\",\n      \"Moneda_Id\": \"DOL\",\n      \"Moneda_ctz\": {{ $('get_exchange_rate').item.json.FEXGetPARAM_CtzResult.FEXResultGet.Mon_ctz }},\n      \"Imp_total\": {{ $('validate_input').item.json.amount }},\n      \"Idioma_cbte\": 1,\n      \"Forma_pago\": \"{{ $('validate_input').item.json.payment_method }}\",\n      \"Incoterms\": \"\",\n      \"Incoterms_Ds\": \"\",\n      \"Obs_comerciales\": \"{{ $('validate_input').item.json.description }}\",\n      \"Obs\": \"\",\n      \"Cmps_asoc\": [],\n      \"Fecha_pago\": \"{{ $('validate_input').item.json.fecha_pago }}\",\n      \"Items\": {\n        \"Item\": [\n          {\n            \"Pro_codigo\": \"0001\",\n            \"Pro_ds\": \"{{ $('validate_input').item.json.description }}\",\n            \"Pro_qty\": {{ $('validate_input').item.json.quantity }},\n            \"Pro_umed\": 7,\n            \"Pro_precio_uni\": {{ $('validate_input').item.json.unit_price }},\n            \"Pro_bonificacion\": 0,\n            \"Pro_total_item\": {{ $('validate_input').item.json.amount }}\n          }\n        ]\n      }\n    }\n  }\n}",
        "options": {}
      }
    },
