    {
      "id": "node-0009",
      "name": "generate_qr",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [0, 200],
      "parameters": {
        "jsCode": "const r = $input.first().json.FEXAuthorizeResult.FEXResultAuth;\nconst inv = $('validate_input').item.json;\nconst ctz = $('get_exchange_rate').item.json.FEXGetPARAM_CtzResult.FEXResultGet.Mon_ctz;\n\nconst QRCodeData = {\n  ver: 1,\n  fecha: r.Fch_cbte,\n  cuit: Number(r.Cuit),\n  ptoVta: Number(r.Punto_vta),\n  tipoCmp: Number(r.Cbte_tipo),\n  nroCmp: Number(r.Cbte_nro),\n  importe: Number(inv.amount),\n  moneda: 'DOL',\n  ctz: Number(ctz),\n  tipoDocRec: 99,\n  nroDocRec: Number(inv.client_tax_id),\n  tipoCodAut: 'E',\n  codAut: Number(r.Cae)\n};\n\nconst qr_code_text = 'https://www.afip.gob.ar/fe/qr/?p=' + Buffer.from(JSON.stringify(QRCodeData)).toString('base64');\n\nreturn [{ json: {\n  qr_code_text: qr_code_text,\n  voucher_result: r,\n  invoice_data: inv\n}}];"
      }
    },
    {
      "id": "node-0010",
      "name": "generate_html",
      "type": "n8n-nodes-base.html",
      "typeVersion": 1.2,
      "position": [220, 200],
      "alwaysOutputData": false,
      "executeOnce": false,
      "parameters": {
        "html": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Factura de Exportacion</title>\n  <style>body { font-family: Arial, sans-serif; width: 750px; margin: 0 auto; padding: 0; background-color: #fff; font-size: 11px; position: absolute; } .invoice { background-color: white; } .original-row { text-align: center; padding: 10px; border-bottom: 1px solid #000; font-weight: bold; font-size: 14px; } .header-row { display: flex; border-bottom: 2px solid #000; position: relative; } .left-header { flex: 1; padding: 10px; border-right: 1px solid #000; } .right-header { flex: 1; padding: 10px; } .code-box { position: absolute; left: 50%; top: 1px; transform: translateX(-50%); border: 1px solid #000; padding: 2px 7px; text-align: center; background-color: white; z-index: 10; } .code-e { font-size: 24px; font-weight: bold; margin-bottom: 5px; } .code-19 { font-size: 10px; } .factura-title { font-weight: bold; font-size: 14px; margin-top: 60px; } .right-details { margin-top: 10px; } .company-row { padding: 10px; border-bottom: 1px solid #000; } .company-details { display: flex; gap: 30px; margin-top: 10px; } .client-section { flex: 1; } .address-section { flex: 1; } .full-width-row { padding: 8px; border-bottom: 1px solid #000; background-color: #f8f8f8; } .summary-row { padding: 10px; border-bottom: 1px solid #000; background-color: #f8f8f8; text-align: right; } .payment-row { display: flex; gap: 30px; padding: 10px; border-bottom: 1px solid #000; align-items: center; } .items-table { width: 100%; border-collapse: collapse; margin-bottom: 0; } .items-table th { background-color: #d0d0d0; border: 1px solid #000; padding: 5px; font-size: 10px; font-weight: bold; text-align: center; } .items-table td { border: 1px solid #000; padding: 5px; font-size: 10px; text-align: center; } .item-description { text-align: left !important; } .total-amount { font-size: 14px; font-weight: bold; margin-top: 5px; } .footer-section { display: flex; padding: 15px; border-top: 1px solid #000; align-items: flex-start; gap: 20px; } .qr-section { text-align: center; } .qr-placeholder { width: 300px; height: 300px; background-color: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 8px; margin-bottom: 5px; } .arca-section { margin-right: 20px; } .cae-section { flex: 1; text-align: left; width: max-content; min-width: max-content; } .field { margin-bottom: 3px; font-size: 11px; } .field-label { font-weight: bold; display: inline-block; } .company-name { font-weight: bold; font-size: 12px; margin-bottom: 8px; margin-top: 60px; } .bold-text { font-weight: 600; }</style>\n</head>\n<body>\n  <div class=\"invoice\">\n    <div class=\"original-row\">ORIGINAL</div>\n    <div class=\"header-row\">\n      <div class=\"code-box\">\n        <div class=\"code-e\">{{ $('create_voucher').item.json.FEXAuthorizeResult.FEXResultAuth.Cbte_tipo || 'E' }}</div>\n        <div class=\"code-19\">COD. 19</div>\n      </div>\n      <div class=\"left-header\">\n        <div class=\"company-name\">DEL PADRE CABRERA RODRIGO DAVID</div>\n        <div class=\"field\"><span class=\"field-label\">Razon Social:</span> DEL PADRE CABRERA RODRIGO DAVID</div>\n        <div class=\"field\"><span class=\"field-label\">Domicilio Comercial:</span> Bolivia 165 - Barrio Nueva Cordoba, Cordoba, Argentina</div>\n        <div class=\"field\"><span class=\"field-label\">Condicion frente al IVA:</span> Responsable Monotributo</div>\n      </div>\n      <div class=\"right-header\">\n        <div class=\"factura-title\">FACTURA DE EXPORTACION</div>\n        <div class=\"right-details\">\n          <div class=\"field\"><span class=\"field-label\">Compr. Nro:</span> {{ $('create_voucher').item.json.FEXAuthorizeResult.FEXResultAuth.Cbte_nro || '001' }}</div>\n          <div class=\"field\"><span class=\"field-label\">Fecha de Emision:</span> {{ ($('create_voucher').item.json.FEXAuthorizeResult.FEXResultAuth.Fch_cbte || '20250101').toString().replace(/(\\d{4})(\\d{2})(\\d{2})/, '$3/$2/$1') }}</div>\n          <div class=\"field\"><span class=\"field-label\">CUIT:</span> {{ $('create_voucher').item.json.FEXAuthorizeResult.FEXResultAuth.Cuit || '20400832278' }}</div>\n          <div class=\"field\"><span class=\"field-label\">Ingresos Brutos:</span> 20-40083227-8</div>\n          <div class=\"field\"><span class=\"field-label\">Fecha de Inicio de Actividades:</span> 01/09/2021</div>\n          <div class=\"field\"><span class=\"field-label\">IVA EXENTO OPERACION DE EXPORTACION</span></div>\n        </div>\n      </div>\n    </div>\n    <div class=\"company-row\">\n      <div class=\"company-details\">\n        <div class=\"client-section\">\n          <div class=\"field\"><span class=\"field-label\">Senores:</span> {{ $('validate_input').item.json.client_name }}</div>\n          <div class=\"field\"><span class=\"field-label\">Pais:</span> {{ $('validate_input').item.json.client_country }}</div>\n          <div class=\"field\"><span class=\"field-label\">CUIT Pais:</span> {{ $('validate_input').item.json.cuit_pais }} ({{ $('validate_input').item.json.client_country }} - Persona juridica)</div>\n          <div class=\"field\"><span class=\"field-label\">ID Impositivo:</span> {{ $('validate_input').item.json.client_tax_id }}</div>\n        </div>\n        <div class=\"address-section\">\n          <div class=\"field\"><span class=\"field-label\">Domicilio:</span> {{ $('validate_input').item.json.client_address }}</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"full-width-row\">\n      <div class=\"field\"><span class=\"field-label\">Divisa:</span> USD - Dolar Estadounidense</div>\n    </div>\n    <div class=\"full-width-row\">\n      <div class=\"field\"><span class=\"field-label\">Destino del Comprobante:</span> {{ $('validate_input').item.json.client_country }}</div>\n    </div>\n    <div class=\"payment-row\">\n      <div class=\"field\"><span class=\"field-label\">Forma de Pago:</span> {{ $('validate_input').item.json.payment_method }}</div>\n      <div class=\"field\"><span class=\"field-label\">Fecha de Pago:</span> {{ $('validate_input').item.json.fecha_pago.toString().replace(/(\\d{4})(\\d{2})(\\d{2})/, '$3/$2/$1') }}</div>\n      <div class=\"field\"><span class=\"field-label\">Incoterms:</span> </div>\n    </div>\n    <table class=\"items-table\">\n      <thead>\n        <tr>\n          <th>Item</th>\n          <th>Descripcion</th>\n          <th>Cantidad</th>\n          <th>Precio Unit. (USD)</th>\n          <th>Total por Item (USD)</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td>1</td>\n          <td class=\"item-description\">{{ $('validate_input').item.json.description }}</td>\n          <td>{{ $('validate_input').item.json.quantity.toFixed(6) }}<br><small>U. Medida: otras unidades</small></td>\n          <td>{{ $('validate_input').item.json.unit_price.toFixed(6) }}</td>\n          <td>{{ $('validate_input').item.json.amount.toFixed(2) }}</td>\n        </tr>\n      </tbody>\n    </table>\n    <div class=\"summary-row\">\n      <div class=\"field\"><span class=\"field-label\">Tipo de Cambio:</span> {{ $('get_exchange_rate').item.json.FEXGetPARAM_CtzResult.FEXResultGet.Mon_ctz }} ARS/USD</div>\n      <div class=\"field\"><span class=\"field-label\">Divisa:</span> USD - Dolar Estadounidense</div>\n      <div class=\"total-amount\"><span class=\"field-label\">Importe Total:</span> {{ $('validate_input').item.json.amount.toFixed(2) }}</div>\n    </div>\n    <div class=\"footer-section\">\n      <div class=\"qr-section\">\n        <img class=\"qr-placeholder\" src=\"{{ 'https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=' + encodeURIComponent($json.qr_code_text) }}\">\n      </div>\n      <div class=\"arca-section\">\n        <div style=\"font-weight: bold; font-size: 14px;\">ARCA</div>\n        <div style=\"font-size: 9px;\">Organismo gubernamental</div>\n        <div style=\"margin-top: 10px; font-weight: bold;\">Comprobante Autorizado</div>\n        <div class=\"bold-text\" style=\"font-size: 9px; margin-top: 10px;\">Esta Agencia no se responsabiliza por la veracidad de los datos ingresados en el detalle de la operacion</div>\n      </div>\n      <div class=\"cae-section\">\n        <div class=\"field\"><span class=\"field-label\">CAE N:</span> {{ $('create_voucher').item.json.FEXAuthorizeResult.FEXResultAuth.Cae || '12345678901234' }}</div>\n        <div class=\"field\"><span class=\"field-label\">Fecha de Vto. de CAE:</span> {{ ($('create_voucher').item.json.FEXAuthorizeResult.FEXResultAuth.Fch_venc_Cae || '20250101').toString().replace(/(\\d{4})(\\d{2})(\\d{2})/, '$3/$2/$1') }}</div>\n      </div>\n    </div>\n  </div>\n</body>\n</html>"
      }
    },
    {
      "id": "node-0011",
      "name": "create_pdf",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 200],
      "parameters": {
        "method": "POST",
        "url": "https://app.afipsdk.com/api/v1/pdfs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.AFIP_SDK_TOKEN }}"
            }
          ]
        },
